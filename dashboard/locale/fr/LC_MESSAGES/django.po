msgid "Last name"
msgstr "Nom de famille"

#: dashboard/forms.py:35
msgid "Email"
msgstr "Email"

#: dashboard/forms.py:37
msgid "Required. Enter a valid email address."
msgstr "Requis. Entrez une adresse email valide."

