#: dashboard/templates/dashboard/password_reset.html:6
#: dashboard/templates/dashboard/password_reset.html:12
msgid "Forgot your password?"
msgstr "Paswoord vergeten?"

#: dashboard/templates/dashboard/password_reset.html:13
msgid ""
"Enter your email address below, and we'll email instructions for setting a "
"new one."
msgstr ""
"Vul hieronder uw e-mailadres in, en we sturen u instructies om een nieuw "
"paswoord in te stellen."

#: dashboard/templates/dashboard/password_reset.html:19
msgid "Send me instructions!"
msgstr "Zend me instructies!"

#: dashboard/templates/dashboard/password_reset_complete.html:5
#: dashboard/templates/dashboard/password_reset_complete.html:11
msgid "Password reset complete"
msgstr "Paswoord reset voltooid"

#: dashboard/templates/dashboard/password_reset_complete.html:14
#, python-format
msgid ""
"\n"
"                Your new password has been set. You can now <a "
"href=\"%(signin_url)s\">sign in</a>.\n"
"            "
msgstr ""
"\n"
"                        Uw nieuw paswoord is ingesteld. U kunt nu <a "
"href=\"%(signin_url)s\">inloggen</a>."

#: dashboard/templates/dashboard/password_reset_confirm.html:6
msgid "Reset your password"
msgstr "Reset uw paswoord"

#: dashboard/templates/dashboard/password_reset_confirm.html:13
msgid "Set a new password!"
msgstr "Nieuw paswoord instellen!"

#: dashboard/templates/dashboard/password_reset_confirm.html:18
msgid "Change my password"
msgstr "Wijzig mijn paswoord"

#: dashboard/templates/dashboard/password_reset_confirm.html:23
msgid ""
"The password reset link was invalid, possibly because it has already been "
"used. Please request a new password reset."
msgstr ""
"De reset paswoord link is ongeldig, mogelijk omdat deze al gebruikt is. "
"Vraag een nieuwe reset aan."

#: dashboard/templates/dashboard/password_reset_done.html:6
msgid "Instructions sent"
msgstr "Instructies verzonden"

#: dashboard/templates/dashboard/password_reset_done.html:12
msgid "Check your inbox."
msgstr "Controleer uw inbox."

#: dashboard/templates/dashboard/password_reset_done.html:14
msgid ""
"We've emailed you instructions for setting your password. You should receive "
"the email shortly!"
msgstr ""
"We hebben u instructies gemaild om uw paswoord in te stellen. U zou de email "
"binnenkort moeten ontvangen!"

