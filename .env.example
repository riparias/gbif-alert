# GBIF Alert - environment variable contract.
#
# Copy to `.env` at the project root and fill in real values for the
# settings you want to override. `settings.py` loads this file
# automatically via python-dotenv. Anything you do NOT set here can be
# left as the documented default below.
#
# For the Docker stack, the same variables are read from the operator's
# `.env` next to `docker-compose.yml`.

# === Required ===
# `settings.py` raises ImproperlyConfigured at startup if any of these
# are missing (whether from env or from local_settings.py).

SECRET_KEY=please-generate-a-strong-secret
SITE_BASE_URL=https://example.org
DJANGO_ALLOWED_HOSTS=example.org
# Origins (scheme + host) the browser may POST from. Required behind a
# reverse proxy on a public domain - without it, every POST (admin login,
# alert creation, etc.) fails with "CSRF verification failed". Must
# include the scheme. Comma-separated for multiple origins.
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.org
SITE_NAME=GBIF Alert - my-instance

# === Database ===
# Postgres + PostGIS connection URL.
# Format: postgis://user:password@host:port/dbname
# Manual deploy: usually postgis://gbif:gbif@localhost:5432/gbif_alert
# Docker (bundled-db profile): postgis://gbif_alert:secret@db:5432/gbif_alert
# Docker (managed Postgres on Dokploy / RDS): point at the managed host
# A `postgres://` or `postgresql://` URL (what managed providers usually
# hand you) is auto-upgraded to the PostGIS backend - the app always uses
# it, so the scheme does not matter. PostGIS must still be installed on
# the database.
DATABASE_URL=postgis://user:password@localhost:5432/gbif_alert

# === Production-required ===
# These have safe defaults so the app starts for plumbing tests, but
# you need to set them for any real deployment.

# Email (notifications, admin error mails).
# Two ways to send:
#  1. SMTP (default) - set the EMAIL_* below and leave EMAIL_BACKEND unset.
#  2. Amazon SES via an IAM role - set EMAIL_BACKEND=django_ses.SESBackend and
#     AWS_SES_REGION_NAME (e.g. eu-west-1). Credentials are taken from the
#     ambient boto3 chain (the ECS/EC2 instance/task role), so no SMTP user,
#     password or access keys are needed. The EMAIL_HOST/PORT/USER/PASSWORD/TLS
#     vars are then ignored. DEFAULT_FROM_EMAIL must be a verified SES identity.
#EMAIL_BACKEND=django_ses.SESBackend
#AWS_SES_REGION_NAME=eu-west-1
EMAIL_HOST=smtp.example.org
EMAIL_PORT=587
EMAIL_HOST_USER=alerts@example.org
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=alerts@example.org
SERVER_EMAIL=alerts@example.org

# Initial map view (front-page map zoom/centre)
MAP_INITIAL_ZOOM=8
MAP_INITIAL_LAT=50.50
MAP_INITIAL_LON=4.47

# GBIF download credentials (used by `python manage.py import_observations`).
# Create a dedicated GBIF account, not your personal one.
GBIF_DOWNLOAD_USERNAME=
GBIF_DOWNLOAD_PASSWORD=

# Default predicate-builder filters. Override by writing a custom builder
# in local_settings.py if you need more flexibility (see
# local_settings.template.py for a worked example).
GBIF_DOWNLOAD_COUNTRY=BE
GBIF_DOWNLOAD_YEAR_MIN=2000

# === Optional, with sensible defaults ===

DEBUG=False
TIME_ZONE=Europe/Brussels

# Minimum level for the `django` logger and its console handler. The
# console handler is always active and writes to stderr, so with
# DEBUG=False this is how 500 tracebacks reach the container logs
# (independently of the ADMINS email handler). Lower to DEBUG for more
# detail, raise to WARNING/ERROR to reduce noise.
DJANGO_LOG_LEVEL=INFO

# Languages enabled in the UI. Subset of supported (en, fr, nl).
ENABLED_LANGUAGES=en,fr,nl

# PrimeVue palette name. One of: emerald, green, lime, red, orange,
# amber, yellow, teal, cyan, sky, blue, indigo, violet, purple, fuchsia,
# pink, rose, slate, gray, zinc, neutral, stone.
PRIMEVUE_PRIMARY_PALETTE=indigo

# Admins for error emails. Format: `Name1 <a@b>, Name2 <c@d>`.
ADMINS=

# Subject-line prefix for outgoing mail.
EMAIL_SUBJECT_PREFIX=[gbif-alert]

# Redis / Valkey URL for django-rq.
# Manual deploy: redis://localhost:6379/0
# Docker: redis://valkey:6379/0
# If your Redis/Valkey requires auth, put the credentials IN the URL, e.g.
# redis://:PASSWORD@host:6379/0 (or redis://default:PASSWORD@host:6379/0 for a
# Valkey ACL user) - and remember CACHE_URL needs them too (see below).
RQ_REDIS_URL=redis://localhost:6379/0

# Optional: separate cache URL for Django's cache framework (used by
# maintenance_mode to share state across processes). Defaults to
# RQ_REDIS_URL, so leave unset unless you want the cache on a different
# Redis/Valkey database (e.g. redis://valkey:6379/1) to keep it isolated
# from the RQ queue. If both this and RQ_REDIS_URL are unset, the cache
# falls back to redis://localhost:6379/0 - so a local Valkey/Redis
# install with default ports just works.
#CACHE_URL=

# Security / HTTPS hardening. All optional. With DEBUG=False these default to
# secure values suited to the standard "behind a TLS-terminating reverse
# proxy" topology, so a normal HTTPS deploy needs none of them. They are here
# for the rare cases that need to opt out or tune.
#  - SESSION/CSRF cookie Secure flag and HTTP->HTTPS redirect default to True
#    in production (DEBUG=False), False in dev. Set SECURE_SSL_REDIRECT=False
#    if your reverse proxy already redirects HTTP to HTTPS.
#  - HSTS defaults to 3600s (1h) in production with no includeSubDomains/
#    preload. Raise it once confident; set to 0 to disable. Only enable
#    includeSubDomains/preload deliberately - they are slow to undo.
#SESSION_COOKIE_SECURE=True
#CSRF_COOKIE_SECURE=True
#SECURE_SSL_REDIRECT=True
#SECURE_HSTS_SECONDS=3600
#SECURE_HSTS_INCLUDE_SUBDOMAINS=False
#SECURE_HSTS_PRELOAD=False

# === Docker-only ===
# Image tag pulled by the compose stack. REQUIRED - the compose file has no
# default, so an unset or empty value aborts the deploy with a hint. Use a
# moving tag like `devel` for a tracking install (pairs with registry polling
# for auto-redeploy), or pin to a release tag (e.g. `1.11.0`) for a stable
# deploy. Uncomment and set before `docker compose up`:
#GBIF_ALERT_TAG=devel

# Host interface and port the app is published on, as `host:port` (the
# container side is fixed at 8000). Defaults to 127.0.0.1:8000 so a
# reverse proxy on the same host can reach it. Running several instances
# on one host? Give each a UNIQUE host port, e.g. 127.0.0.1:8001 - a
# host port can only be held by one container. Platforms that route over
# the Docker network (Dokploy/Traefik) do not need this bind, but it
# must still be unique to avoid a clash at `docker compose up`.
#GBIF_ALERT_BIND=127.0.0.1:8000

# Cron schedules for the in-stack ofelia scheduler. Format is SIX fields
# with leading seconds: "second minute hour day month dayofweek". A
# five-field standard cron expression like "0 2 * * *" is silently
# misread as "every hour at HH:02:00" - always include the leading 0
# for seconds. Evaluated in the scheduler container's timezone (UTC).
IMPORT_OBSERVATIONS_SCHEDULE=0 0 2 * * *
SEND_NOTIFICATIONS_SCHEDULE=0 0 14 * * *

# Optional GDAL/GEOS library paths for GeoDjango. Leave unset on Linux/Docker
# (auto-detected). On macOS (Homebrew) set them so local dev runs under the
# default settings module, e.g.:
#GDAL_LIBRARY_PATH=/opt/homebrew/lib/libgdal.dylib
#GEOS_LIBRARY_PATH=/opt/homebrew/lib/libgeos_c.dylib

# Set to true ONLY for frontend dev with the Vite dev server (`npm run vite-dev`).
# Leave unset/false in production and tests so the built bundle is served.
#DJANGO_VITE_DEV_MODE=false
